LOGS_ENCRYPTION_KEY=
 
# Number of days to retain logs. Default 14.
LOG_RETENTION_DAYS=14

CRED_ENCRYPTION_KEY=

ID_CREATION_SECRET=

# URL used for callbacks
API_URL=

PROXY_URL=

## Stripe credentials
STRIPE_SECRET_KEY=

# Google Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Azure Credentials
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

## Stripe product IDs
