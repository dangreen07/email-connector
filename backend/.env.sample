
# Clerk Publishable Key
CLERK_PUBLISHABLE_KEY=
 
# Clerk Secret Key
CLERK_SECRET_KEY=
 
# Neon Database URL
DATABASE_URL=
 
# Logging: encryption key used to encrypt stored payloads (use a strong secret)
