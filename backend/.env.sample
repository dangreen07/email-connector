NODE_ENV=development

FRONTEND_URL=

# Clerk Publishable Key
CLERK_PUBLISHABLE_KEY=
 
# Clerk Secret Key
CLERK_SECRET_KEY=
 
# Database URL
DATABASE_URL=

# Redis URL
